{
	"name": "dynamic_products",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureBlobStorage1",
			"type": "LinkedServiceReference"
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@concat('products_',formatDateTime(utcNow(),'yyyyMMdd'),'.csv')",
					"type": "Expression"
				},
				"folderPath": "source",
				"container": "delta"
			},
			"columnDelimiter": ",",
			"escapeChar": "\"",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "product_id",
				"type": "String"
			},
			{
				"name": "product_name",
				"type": "String"
			},
			{
				"name": "category",
				"type": "String"
			},
			{
				"name": "price",
				"type": "String"
			},
			{
				"name": "created_at",
				"type": "String"
			}
		]
	}
}